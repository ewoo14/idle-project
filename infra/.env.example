# idle-project 개발용 환경 변수 예시.
# 사용 방법: 이 파일을 .env 로 복사하고 값을 수정하세요.
#   cp .env.example .env
#
# 운영 환경은 절대 이 값을 그대로 쓰지 마세요. 모든 비밀은 회전 가능해야 합니다.

# ===== PostgreSQL =====
POSTGRES_USER=idle
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=idle
POSTGRES_PORT=5432

# ===== Redis =====
REDIS_PORT=6379

# ===== pgAdmin (개발용) =====
PGADMIN_EMAIL=admin@idle.local
PGADMIN_PASSWORD=change_me_local_only
PGADMIN_PORT=5050

# ===== 서버 (PR #7 이후) =====
NODE_ENV=development
SERVER_PORT=3000
LOG_LEVEL=info
JWT_KEY_ID=v1

# JWT 키 — RS256. 개발 키는 다음과 같이 생성:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# 생성한 파일은 .gitignore 됨. infra/secrets/ 또는 docker secrets 로 마운트.

# ===== 관측 (1.0 이후) =====
PROMETHEUS_PORT=9090
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_local_only
GRAFANA_PORT=3001
