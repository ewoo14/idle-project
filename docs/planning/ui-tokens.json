{
  "$schema": "https://json.schemastore.org/base.json",
  "$comment": "idle-project UI 토큰. docs/planning/04-art-direction.md §3.2 의 표를 1:1 직렬화. UE5 UMG / 웹 어드민 / 디자이너 작업 모두 본 JSON 을 단일 source of truth 로 한다.",
  "version": "0.1.0-placeholder",
  "color": {
    "bg": {
      "primary":   "#1A1B2E",
      "panel":     "#252845"
    },
    "text": {
      "primary":   "#F5F5F0",
      "muted":     "#A0A4B8"
    },
    "accent": {
      "gold":      "#F4C44A",
      "blue":      "#6BB7F0",
      "red":       "#E5556B"
    },
    "errors": {
      "critical":  "#FF4D5E",
      "warn":      "#F0A43A",
      "info":      "#5BA7F0",
      "auth":      "#C071F2"
    },
    "rarity": {
      "common":    "#B0B5C0",
      "rare":      "#5B8BC0",
      "epic":      "#A05BC0",
      "unique":    "#5BC07A",
      "legendary": "#F0A040",
      "transcendent": "#40D0E8",
      "mythic": {
        "$type": "linear-gradient",
        "angle": 45,
        "stops": [
          { "at": 0.0, "color": "#FF7B00" },
          { "at": 1.0, "color": "#00B4FF" }
        ],
        "$comment": "Use start/end colors in UE Theme::RarityMythicStart/End for UMG fallback."
      }
    }
  },
  "rarityDisplay": {
    "order": ["common", "rare", "epic", "unique", "legendary", "transcendent", "mythic"],
    "labels": {
      "ko": {
        "common": "일반",
        "rare": "레어",
        "epic": "에픽",
        "unique": "유니크",
        "legendary": "전설",
        "transcendent": "초월",
        "mythic": "신화"
      },
      "en": {
        "common": "Common",
        "rare": "Rare",
        "epic": "Epic",
        "unique": "Unique",
        "legendary": "Legendary",
        "transcendent": "Transcendent",
        "mythic": "Mythic"
      }
    },
    "$comment": "PR #65 removes Uncommon. Transcendent appears only in item/rune context; prestige Transcendence keeps TRANSCEND_* UI keys."
  },
  "typography": {
    "korean": {
      "family":  "Pretendard",
      "weights": [400, 500, 700],
      "selfHost": "client/Content/Fonts/Pretendard/ (PR #2 에서 추가)"
    },
    "english": {
      "family":  "Inter",
      "weights": [400, 600]
    },
    "numeric": {
      "family": "DungGeunMo",
      "$comment": "데미지/수치 폰트. 라이선스: SIL OFL 1.1 (재배포 가능)."
    }
  },
  "motion": {
    "ui-ease-out": { "duration_ms": 200, "curve": "ease-out" },
    "damage-pop":  { "duration_ms": 350, "curve": "ease-out", "translateY_px": -32, "fadeOut": true },
    "reward-card": { "duration_ms": 450, "curve": "ease-in-out", "flip": "Y", "particles": true }
  },
  "radius": {
    "sm": 4,
    "md": 6,
    "lg": 8
  },
  "hud": {
    "questLog": {
      "anchor": "top-right",
      "marginRightPx1080": 28,
      "topPx1080": 92,
      "widthViewportRatio": 0.36,
      "minWidthPx1080": 420,
      "maxWidthPx1080": 620,
      "headerHeightPx1080": 54,
      "sectionHeightPx1080": 26,
      "rowHeightPx1080": 58,
      "rowGapPx1080": 8,
      "scaleByCanvasHeight": {
        "baseHeight": 1080,
        "min": 1.0,
        "max": 2.0
      },
      "sectionColors": {
        "main": "{color.accent.blue}",
        "daily": "{color.text.muted}",
        "weekly": "{color.accent.gold}"
      },
      "progressColor": "{color.accent.blue}",
      "claimColor": "{color.accent.gold}",
      "panelColor": "{color.bg.panel}",
      "rowColor": "{color.bg.primary}"
    }
  },
  "$todo": [
    "다크/라이트 분리는 1.0 출시 전 결정 (현재 다크 단일).",
    "Pretendard 셀프호스팅 경로/라이선스 표기 — PR #2.",
    "UE5 C++ 미러: client/Source/IdleProject/UI/UIThemeTokens.h"
  ]
}
